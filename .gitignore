*.exe
*.dll
*.lib
*.a

# macOS específico
.env.local.php

# Linux específico
*.so

# ===== CONFIGURACIÓN LOCAL (Ignore pero permite patterns específicos) =====
# Permitir .env.example (template)
!.env.example
!.env.production.example

# Permitir .gitkeep
!.gitkeep

# Permitir docker-compose.yml
!docker-compose.yml
!docker-compose.override.yml.example

# Permitir archivos de configuración
!.htaccess
!.nginx.conf
!/config/
!/docker/
