.notes
personal/
NOTAS.md

# ===== DEPENDENCIAS OPCIONALES =====
package-lock.json
yarn.lock

# ===== API KEYS Y SECRETOS =====
.aws/
.gcloud/
credentials/
secrets/
tokens/

# ===== ARCHIVOS DE PROYECTO ESPECÍFICOS =====
dist/
build/
out/
*.egg-info/
.pytest_cache/
.tox/
htmlcov/

# ===== NETLIFY =====
/.netlify/
.netlify/

# ===== VERCEL =====
.vercel/

