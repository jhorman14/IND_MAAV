# Git Ignore - IND_MAAV Project

# ===== AMBIENTE =====
.env
.env.local
.env.*.local
.DS_Store
Thumbs.db

# ===== BACKEND - PHP =====
/backend/vendor/
/backend/node_modules/
/backend/storage/logs/*
!/backend/storage/logs/.gitkeep
/backend/storage/app/*
!/backend/storage/app/.gitkeep
/backend/bootstrap/cache/*
!/backend/bootstrap/cache/.gitkeep
/backend/.php-cs-fixer.cache
/backend/composer.lock
/backend/public/storage
/backend/public/hot

# ===== FRONTEND - NODE =====
/frontend/node_modules/
/frontend/dist/
/frontend/build/
/frontend/.vite/
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*

# ===== IDEs =====
# VS Code
/.vscode/
!/.vscode/extensions.json
/.vscode/*.log
*.code-workspace

# PhpStorm / IntelliJ
/.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.vim/
.swp
.swo
*~

# Nano
.~*

# Emacs
*~
\#*\#
.\#*

# ===== SISTEMA OPERATIVO =====
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

